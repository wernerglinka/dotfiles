# ~/.npmrc — local npm config. Intentionally carries NO auth token.
#
# Publishing strategy for this account:
#   Long-lived classic tokens are not stored on this machine. Each
#   @wernerglinka/* package and metalsmith-plugin-mcp-server publishes
#   from GitHub Actions via npm's trusted publishing (OIDC), with
#   provenance enabled. The workflow uses `permissions: id-token: write`
#   and runs `npm publish --provenance --access public`. No secret on
#   the local machine is required to publish.
#
# Day-to-day commands like `npm install`, `npm test`, `npm run` work
# anonymously against the public registry. The only operation that
# would need credentials is a direct `npm publish` from this terminal,
# which is the exact thing we are deliberately not doing.

registry=https://registry.npmjs.org/
@wernerglinka:registry=https://registry.npmjs.org/

# Sensible defaults for `npm init`
init-author-name=Werner Glinka
init-license=MIT

# Keep package-lock.json honest
fund=false
audit-level=high
