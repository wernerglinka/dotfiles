# Template for ~/.ssh/config.
# bootstrap.sh copies this to ~/.ssh/config only if no config file exists
# there already. Private keys are never committed; only this template is.
#
# SSH on this Mac uses 1Password as its SSH agent. The private key lives
# inside the locked 1Password vault, not at ~/.ssh/id_ed25519. Each
# connection prompts for Touch ID via 1Password.

Host *
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
  IdentitiesOnly yes
